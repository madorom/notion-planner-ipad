# Notion integration token. Keep this server-side only.
NOTION_TOKEN=

# Password required before the planner UI can call the Notion API routes.
APP_PASSWORD=

# Long random string used to sign the login cookie.
AUTH_SECRET=

# Google Calendar OAuth web client credentials.
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Optional. Defaults to {origin}/api/google/callback.
# For Vercel production, register and use:
# https://your-app.vercel.app/api/google/callback
GOOGLE_REDIRECT_URI=
